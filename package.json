{
  "name": "40k-calculator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm --workspace @40k-calculator/web run dev",
    "build": "npm --workspace @40k-calculator/web run build",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "data-release": "node scripts/data-release-cli.mjs",
    "data-release:validate": "node scripts/data-release-cli.mjs validate --catalog apps/web/src/data/catalog.json",
    "test:data-release-cli": "node --test scripts/data-release-cli.test.mjs",
    "verify:data-release": "node scripts/verify-release-files.mjs",
    "check": "npm run typecheck && npm run test && npm run test:data-release-cli && npm run verify:data-release && npm run build"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
